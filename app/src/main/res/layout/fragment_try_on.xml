<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/arFragmentContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Top category buttons -->
    <LinearLayout
        android:id="@+id/categoryLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="10dp"
        android:background="#AA000000"
        android:layout_gravity="top"
        android:elevation="6dp">
        <Button
            android:id="@+id/btnNecklace"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Necklace" />


        <Button
            android:id="@+id/btnRing"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Finger Ring" />

        <Button
            android:id="@+id/btnNoseRing"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Nose Ring" />

        <Button
            android:id="@+id/btnEarRing"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:text="Ear Ring" />
    </LinearLayout>

    <!-- Swap button -->
    <Button
        android:id="@+id/btnSwap"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Swap"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:backgroundTint="#FF6200EE"
        android:textColor="#FFFFFF" />

</FrameLayout>

